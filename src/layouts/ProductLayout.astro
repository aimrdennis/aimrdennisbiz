---
import SeoHead from './ProductLayout/Seo.astro';
import Header from './ProductLayout/Header.astro';
import SecHeader from './ProductLayout/SecHeader.astro';
import SecFooter from './ProductLayout/SecFooter.astro';
import Footer from './ProductLayout/Footer.astro';
import Scripts from './ProductLayout/Scripts.astro';

import Topbar from './ProductLayout/Topbar.astro';
import Categories from './ProductLayout/Categories.astro';

import { SITE } from '../lib/site';

const {
  slug = '',
  product = {}
} = Astro.props;
---

<!doctype html>

<html lang="en">

<head>
<SeoHead
  title={product.title}
  description={product.description}
  image={product.image}
  slug={slug}
amp={SITE.url(`/product/${slug}/amp/`)}
/>

<script
type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.title,
    image: product.image,
    description: product.description,
    url: SITE.url(`/product/${slug}/`),
    category: product.category,
    offers: {
      "@type": "Offer",
      price: product.price?.replace("$", ""),
      priceCurrency: "USD"
    }
  })}
/>
</head>

<body>
<Topbar product={product} slug={slug} />

<Header product={product} slug={slug} />

<SecHeader product={product} slug={slug} />

<Categories product={product} slug={slug} />



<main class="container">
  <slot />
</main>

<SecFooter product={product} slug={slug} />

<Footer product={product} slug={slug} />

<Scripts />

</body>
</html>

<style is:global>
:root{
--bg:#f4f6fb;
--card:#fff;
--text:#111827;
--muted:#6b7280;
--primary:#5865f2;
--dark:#0f172a;
--border:#e5e7eb;
--shadow:0 10px 30px rgba(0,0,0,.08);
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:var(--bg);
font-family:Inter,sans-serif;
color:var(--text);
}

.container{
max-width:1440px;
margin:auto;
padding:40px 20px;
}

a{
text-decoration:none;
color:inherit;
}

img{
max-width:100%;
display:block;
}
</style>
