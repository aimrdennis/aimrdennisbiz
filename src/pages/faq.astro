---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../lib/site';

const pageTitle =
  'FAQ AI Mr Dennis - Pertanyaan Umum Seputar AI Otomatis dan Analisis Pintar';

const pageDescription =
  'Temukan jawaban lengkap seputar AI Mr Dennis, aplikasi AI otomatis yang membantu analisis data secara cepat, praktis, dan efisien. Pelajari cara kerja, fitur, keunggulan, serta informasi penting lainnya dalam halaman FAQ resmi AI Mr Dennis.';
